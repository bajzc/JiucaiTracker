# 复制为 .env 并填入真实 key（.env 已被 .gitignore 忽略）

# ASR 本地跑（faster-whisper），不需要任何 key。
# 唯一必填：阿里云百炼，用于向量 / 重排 / 生成。
# https://bailian.console.aliyun.com  → API-KEY
DASHSCOPE_API_KEY=sk-xxx

# === 以下都可选，仅切换供应商时才需要 ===
# 切回云端 Paraformer 转写（asr.provider=dashscope）时需 OSS 凭证：
# OSS_ACCESS_KEY_ID=LTAI-xxx
# OSS_ACCESS_KEY_SECRET=xxx
# OpenAI whisper-1（asr.provider=openai）：
# OPENAI_API_KEY=sk-xxx
# SiliconFlow（embedding/rerank.format 切回 siliconflow）：
# EMBED_API_KEY=sk-xxx
